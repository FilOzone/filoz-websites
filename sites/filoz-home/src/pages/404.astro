---
import BaseLayout from '../layouts/BaseLayout.astro'
---
<BaseLayout title="Page not found" wfPage="66a2ad2993901f5253eecd01">
    <section class="section_hero">
        <div class="padding-global padding-section-xhuge">
            <div class="container-large">
                <div class="text-align-center">
                    <div class="w-layout-vflex header-wrapper">
                        <div class="margin-bottom margin-small">
                            <img src="/images/logos/symbol.svg" loading="lazy" alt="logo" class="main-icon"/>
                        </div>
                        <div class="margin-bottom margin-small">
                            <h1 class="heading-style-h1 bold-header">404</h1>
                            <h2 class="heading-style-h1">Page not found</h2>
                        </div>
                        <div class="max-width-large">
                            <p class="text-size-medium">
                                The page you're looking for doesn't exist or may have been moved.
                            </p>
                        </div>
                        <div class="margin-top margin-xmedium">
                            <div class="button-group align-center">
                                <a href="/" class="button-primary w-inline-block">
                                    <div class="button-text">Back to home</div>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
