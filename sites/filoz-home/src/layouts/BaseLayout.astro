---
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
import GlobalStyles from '../components/GlobalStyles.astro'

interface Props {
  title?: string
  description?: string
  coverImage?: string
  /** Webflow page ID - drives IX2 animations. Set per page/section. */
  wfPage: string
  /** Section name - controls conditional blog CSS loading */
  section?: string
}

const SITE_DESCRIPTION = 'Empowering the Future of Decentralized Storage'
const { title, description, coverImage, wfPage, section } = Astro.props

const pageTitle = title ? `${title} | FilOz` : 'FilOz'
const metaDescription = description ?? SITE_DESCRIPTION
const ogTitle = title ?? 'FilOz'
const isBlog = section === 'blog'
const canonical = new URL(Astro.url.pathname, Astro.site).href
---
<!DOCTYPE html>
<html data-wf-domain="www.filoz.org" data-wf-page={wfPage} data-wf-site="66a2ad2993901f5253eecd05" lang="en">
<head>
    <meta charset="utf-8"/>
    <style>.wf-force-outline-none[tabindex="-1"]:focus{outline:none;}</style>

    <title>{pageTitle}</title>

    <meta content={metaDescription} name="description">
    <meta content={ogTitle} property="og:title">
    <meta content={metaDescription} property="og:description">
    {coverImage && <meta content={new URL(coverImage, Astro.site).href} property="og:image" />}
    <meta content={ogTitle} property="twitter:title">
    <meta content={metaDescription} property="twitter:description">
    {coverImage && <meta content={new URL(coverImage, Astro.site).href} property="twitter:image" />}
    <meta property="og:type" content="website">
    <meta content="summary_large_image" name="twitter:card">
    <meta content="width=device-width, initial-scale=1" name="viewport">
    <link rel="canonical" href={canonical}>

    <!-- Webflow CSS -->
    <link href="/css/webflow.css" rel="stylesheet" type="text/css">

    <!-- Local Fonts -->
    <link rel="stylesheet" href="/css/fonts.css" media="all">

    <!-- Common Styles -->
    <link rel="stylesheet" href="/css/common.css" type="text/css">

    {isBlog && (
      <>
        <link rel="stylesheet" href="/css/index-custom.css" type="text/css">
        <link rel="stylesheet" href="/css/single-custom.css" type="text/css">
      </>
    )}

    <!-- Webflow data-w-id responsive styles -->
    <style set:html={`@media (min-width:992px) {html.w-mod-js:not(.w-mod-ix) [data-w-id="92e0151a-7b29-7462-0e54-4049b17fa7ff"] {width:33%;}html.w-mod-js:not(.w-mod-ix) [data-w-id="92e0151a-7b29-7462-0e54-4049b17fa7fd"] {width:33%;}html.w-mod-js:not(.w-mod-ix) [data-w-id="92e0151a-7b29-7462-0e54-4049b17fa7fe"] {width:33%;height:33PX;}}@media (max-width:991px) and (min-width:768px) {html.w-mod-js:not(.w-mod-ix) [data-w-id="92e0151a-7b29-7462-0e54-4049b17fa7fe"] {height:33%;}html.w-mod-js:not(.w-mod-ix) [data-w-id="92e0151a-7b29-7462-0e54-4049b17fa7ff"] {width:33%;height:33%;}html.w-mod-js:not(.w-mod-ix) [data-w-id="92e0151a-7b29-7462-0e54-4049b17fa7fd"] {width:33%;height:33%;}}@media (max-width:767px) and (min-width:480px) {html.w-mod-js:not(.w-mod-ix) [data-w-id="92e0151a-7b29-7462-0e54-4049b17fa7fe"] {height:33%;}html.w-mod-js:not(.w-mod-ix) [data-w-id="92e0151a-7b29-7462-0e54-4049b17fa7ff"] {width:33%;height:33%;}html.w-mod-js:not(.w-mod-ix) [data-w-id="92e0151a-7b29-7462-0e54-4049b17fa7fd"] {width:33%;height:33%;}}@media (max-width:479px) {html.w-mod-js:not(.w-mod-ix) [data-w-id="92e0151a-7b29-7462-0e54-4049b17fa7fe"] {height:33%;}html.w-mod-js:not(.w-mod-ix) [data-w-id="92e0151a-7b29-7462-0e54-4049b17fa7ff"] {width:33%;height:33%;}html.w-mod-js:not(.w-mod-ix) [data-w-id="92e0151a-7b29-7462-0e54-4049b17fa7fd"] {width:33%;height:33%;}}`} />

    <!-- Webflow JS init (touch detection) -->
    <script is:inline>!function(o,c){var n=c.documentElement,t=" w-mod-";n.className+=t+"js",("ontouchstart"in o||o.DocumentTouch&&c instanceof DocumentTouch)&&(n.className+=t+"touch")}(window,document);</script>

    <!-- Favicon -->
    <link href="/images/tab-bg.png" rel="shortcut icon" type="image/x-icon"/>
    <link href="/images/tab-bg.png" rel="apple-touch-icon"/>

    <!-- [Attributes by Finsweet] CMS Slider -->
    <script async src="/js/cmsslider.js"></script>
</head>
<body class="body">
    <div class="page-wrapper">
        <GlobalStyles />
        <Nav />
        <main class="main-wrapper">
            <slot />
            <Footer />
        </main>
    </div>

    <!-- jQuery -->
    <script is:inline src="/js/jquery-3.5.1.min.js"></script>
    <!-- Webflow JS chunks -->
    <script is:inline src="/js/webflow.schunk.36b8fb49256177c8.js"></script>
    <script is:inline src="/js/webflow.schunk.8208d3e53b97e3c7.js"></script>
    <script is:inline src="/js/webflow.schunk.45325fabecaaed19.js"></script>
    <script is:inline src="/js/webflow.schunk.a5328fc6e4f79712.js"></script>
    <!-- Webflow main -->
    <script is:inline src="/js/webflow.f8334037.js"></script>
    <!-- Tab navigation -->
    <script is:inline>
var Webflow = Webflow || [];
Webflow.push(function() {

  $('.tab-wrapper').on('click', '.tab_previous, .tab_next', function() {

    var direction = $(this).hasClass('tab_previous') ? -1 : 1;
    var tablinks = $(this).parent().find('.w-tab-menu');
    var index = tablinks.find('.w--current').index() + direction;
    index = index >= tablinks.children().length ? 0 : index;
    tablinks.find('.w-tab-link').eq(index).trigger('click');

  });

});
    </script>
</body>
</html>
